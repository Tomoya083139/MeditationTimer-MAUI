<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Meditation.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Meditation"
    xmlns:views="clr-namespace:Meditation.Views"
    Title="瞑想タイマー">

    <!-- タブバー：タイマー / カレンダー -->
    <TabBar>
        <Tab Title="タイマー">
            <ShellContent
                Route="MainPage"
                ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <Tab Title="カレンダー">
            <ShellContent
                Route="CalendarPage"
                ContentTemplate="{DataTemplate views:CalendarPage}" />
        </Tab>
    </TabBar>
</Shell>
